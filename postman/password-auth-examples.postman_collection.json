{
  "info": {
    "name": "Password Auth Examples",
    "_postman_id": "a1b2c3-password-examples",
    "description": "Examples for set-password-by-otp, setPassword, changePassword endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Set Password By OTP (unauthenticated)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"NewPass123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/set-password-by-otp",
          "host": ["{{baseUrl}}"],
          "path": ["api","auth","set-password-by-otp"]
        }
      },
      "response": [
        {
          "name": "Success",
          "originalRequest": {},
          "status": "OK",
          "code": 200,
          "_body": "{ \"success\": true, \"message\": \"Password set successfully. Please log in.\" }"
        }
      ]
    },
    {
      "name": "Set Password (authenticated)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"password\": \"NewPass123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/setPassword",
          "host": ["{{baseUrl}}"],
          "path": ["api","auth","setPassword"]
        }
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "_body": "{ \"success\": true, \"message\": \"Password set successfully\" }"
        }
      ]
    },
    {
      "name": "Change Password (authenticated)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"oldPassword\": \"OldPass123\",\n  \"newPassword\": \"NewPass456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/changePassword",
          "host": ["{{baseUrl}}"],
          "path": ["api","auth","changePassword"]
        }
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "_body": "{ \"success\": true, \"message\": \"Password changed successfully. Please log in again.\" }"
        }
      ]
    }
  ]
}

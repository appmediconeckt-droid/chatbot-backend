{
  "info": {
    "name": "Location API Tests",
    "description": "End-to-end tests for /api/location/* endpoints. Run requests in order. Login response sets {{accessToken}} automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "email", "value": "" },
    { "key": "password", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "0. Health check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "1. Login (sets accessToken)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
              "if (json.user && json.user._id) pm.collectionVariables.set('userId', json.user._id);",
              "pm.test('login ok', () => pm.response.code === 200);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "2. POST /api/location/update — Mumbai (valid)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"latitude\": 19.0760,\n  \"longitude\": 72.8777,\n  \"event\": \"login\"\n}"
        },
        "url": "{{baseUrl}}/api/location/update"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.code === 200);",
              "const data = pm.response.json().data;",
              "pm.test('has GeoJSON Point', () => data.current.type === 'Point');",
              "pm.test('coords saved as [lng, lat]', () => Array.isArray(data.current.coordinates) && data.current.coordinates.length === 2);",
              "pm.test('reverse geocoded address present', () => typeof data.current.address === 'string');"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. POST /api/location/update — invalid lat (400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"latitude\": 200,\n  \"longitude\": 72.8777\n}"
        },
        "url": "{{baseUrl}}/api/location/update"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('status 400', () => pm.response.code === 400);"],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. POST /api/location/update — missing fields (400)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": "{{baseUrl}}/api/location/update"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('status 400', () => pm.response.code === 400);"],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. GET /api/location/counsellors/nearby — explicit coords",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/location/counsellors/nearby?lat=19.076&lng=72.8777&radiusKm=25"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', () => pm.response.code === 200);",
              "pm.test('has count + data array', () => {",
              "  const j = pm.response.json();",
              "  return typeof j.count === 'number' && Array.isArray(j.data);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. GET /api/location/counsellors/nearby — no params (uses my saved location)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/location/counsellors/nearby"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200 (because step 2 saved my location)', () => pm.response.code === 200);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "7. GET /api/location/admin/pending — non-admin (expect 403)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/location/admin/pending"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('non-admin blocked (403)', () => pm.response.code === 403);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "8. POST /api/location/admin/:id/verify — non-admin (expect 403)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"approve\": true,\n  \"notes\": \"manual test\"\n}"
        },
        "url": "{{baseUrl}}/api/location/admin/{{userId}}/verify"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('non-admin blocked (403)', () => pm.response.code === 403);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
